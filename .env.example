# HTTP port the API listens on. Default: 3000.
PORT=3000

# Postgres connection string. Required.
DATABASE_URL=postgres://nmail:nmail@localhost:5432/nmail

# Shared secret required by POST /inbound/decision (the inbound SMTP policy).
# Required. Send it as Authorization: Bearer <token>, x-inbound-decision-token,
# or ?token=<token>.
INBOUND_DECISION_TOKEN=change-me

# Shared secret required by POST /inbound/notifications.
INBOUND_NOTIFICATION_TOKEN=change-me-notifications

# The Firebase Admin SDK reads the project and service-account credentials from
# this JSON file.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional VAPID identity for UnifiedPush/Web Push. Configure all three values
# together. Generate the key pair once with: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_SUBJECT=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# Shared secret for POST /outbound/decision (the nostr -> SMTP policy).
# Optional: when unset, the outbound route is not registered. Same auth as above
# with x-outbound-decision-token.
OUTBOUND_DECISION_TOKEN=change-me-three

# Max accepted body size (bytes) for POST /outbound/decision, so the full .eml
# fits. Must be larger than the biggest plan message size. Default: 33554432 (32 MB).
OUTBOUND_MAX_BODY_BYTES=33554432

# Password that enables the /admin console (identities, accounts, plans, domains).
# Optional: when unset, the admin routes are not registered.
ADMIN_PASSWORD=change-me-too

# HMAC key for POST /inbound/role (role-mailbox mail from the haraka-webhook role
# webhook). Optional: when unset, the role route is not registered. Must match the
# plugin's WEBHOOK_SIGNING_KEY so its timestamp+token signature verifies.
WEBHOOK_SIGNING_KEY=change-me-four

# Max accepted body size (bytes) for POST /inbound/role, so the full .eml fits.
# Default: 33554432 (32 MB).
ROLE_WEBHOOK_MAX_BODY_BYTES=33554432
